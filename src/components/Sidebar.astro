---
import { groupTabs, resolveTabPing, type Tab } from "../lib/config";
import { resolveIcon } from "../lib/icons";

interface Props {
	tabs: Tab[];
	defaultTabId: string;
	groupOrder?: string[];
	pingAll?: boolean;
}

const { tabs, defaultTabId, groupOrder, pingAll } = Astro.props;

const groups = groupTabs(tabs, groupOrder).map((g) => ({
	label: g.label,
	tabs: g.tabs.map((tab) => ({
		tab,
		icon: resolveIcon(tab.icon),
		pingEnabled: !!resolveTabPing(tab, pingAll),
	})),
}));
---

<nav class="sidebar" aria-label="Sites">
	<ul class="tabs" role="tablist">
		{
			groups.map((group, groupIndex) => (
				<>
					{groupIndex > 0 && (
						<li
							class="group-divider"
							role="separator"
							aria-label={group.label ?? undefined}
						/>
					)}
					{group.tabs.map(({ tab, icon, pingEnabled }) => (
						<li>
							<button
								type="button"
								class:list={[
									"tab-button",
									{ active: tab.id === defaultTabId },
								]}
								role="tab"
								aria-selected={
									tab.id === defaultTabId ? "true" : "false"
								}
								data-tab-id={tab.id}
								data-preload={tab.preload ? "1" : "0"}
								data-url={tab.url}
								data-name={tab.name}
								data-ping={pingEnabled ? "1" : "0"}
								data-group={group.label ?? ""}
								aria-label={
									group.label
										? `${tab.name} — ${group.label}`
										: tab.name
								}
							>
								<span class="icon" aria-hidden="true">
									{icon.kind === "image" ? (
										<img src={icon.value} alt="" loading="lazy" />
									) : (
										<span class="emoji">{icon.value}</span>
									)}
								</span>
								<span class="label">{tab.name}</span>
								{pingEnabled && (
									<span
										class="health-dot"
										aria-hidden="true"
									/>
								)}
							</button>
						</li>
					))}
				</>
			))
		}
	</ul>
</nav>
